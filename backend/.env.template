# Update your .env file with the correct MySQL credentials

# First, check your MySQL password:
# 1. Open MySQL command line or MySQL Workbench
# 2. Try connecting with: mysql -u root -p
# 3. Enter your MySQL root password when prompted

# Then update the .env file in C:\Farmchainx\backend\.env

# Replace the DB_PASSWORD value with your actual MySQL root password:

DB_URL=jdbc:mysql://localhost:3306/farmchainx
DB_USERNAME=root
DB_PASSWORD=<your_actual_mysql_password_here>
DB_DRIVER=com.mysql.cj.jdbc.Driver

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=""
MAIL_PASSWORD=<your_google_app_password_here>
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_FROM=""

# Other settings
SHOW_EMAIL_CODE_RESPONSE=false
EMAIL_ENABLED=true
JPA_HIBERNATE_DDL_AUTO=update
JPA_SHOW_SQL=true
GOOGLE_CLIENT_ID=""

