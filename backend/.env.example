# ============================================
# Farmchainx Backend - Environment Template
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file

# ============================================
# Database Configuration
# ============================================
# MySQL Connection Details
DB_URL=jdbc:mysql://localhost:3306/farmchainx
DB_USERNAME=root
DB_PASSWORD=your_mysql_root_password_here
DB_DRIVER=com.mysql.cj.jdbc.Driver

# ============================================
# Email Configuration (Gmail SMTP)
# ============================================
# Get App Password from: https://myaccount.google.com/apppasswords
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Select Mail and Windows Computer (or your device)
# 4. Generate a 16-character App Password
# 5. Copy that password below

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16_char_app_password_here
MAIL_FROM=your_gmail@gmail.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# ============================================
# Google OAuth Configuration
# ============================================
# Get from: https://console.cloud.google.com/apis/credentials
# 1. Go to Google Cloud Console
# 2. Create OAuth 2.0 Credentials (Web Application)
# 3. Copy the Client ID

GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# ============================================
# Hibernate/JPA Configuration
# ============================================
JPA_HIBERNATE_DDL_AUTO=update
JPA_SHOW_SQL=true

# ============================================
# Email Settings
# ============================================
SHOW_EMAIL_CODE_RESPONSE=false
EMAIL_ENABLED=true

# ============================================
# Razorpay Configuration (Test Mode)
# ============================================
# Get keys from Razorpay Dashboard -> Account & Settings -> API Keys (Test Mode)
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_secret
RAZORPAY_API_BASE=https://api.razorpay.com/v1

